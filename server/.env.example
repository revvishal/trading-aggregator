# ==============================================
# Trading Aggregator Server Configuration
# ==============================================

# Server port (default: 3001)
PORT=3001

# Frontend URL for CORS and redirects
FRONTEND_URL=http://localhost:3000

# Webhook secret (optional) - if set, TradingView must send this
# as X-Webhook-Secret header for authentication
WEBHOOK_SECRET=

# Zerodha Kite Connect API credentials
# Get these from https://developers.kite.trade/
KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here

# Secondary Zerodha Account (optional)
SECONDARY_KITE_API_KEY=
SECONDARY_KITE_API_SECRET=

# Neon PostgreSQL Database
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# App Authentication
APP_USERNAME=admin
APP_PASSWORD=changeme
JWT_SECRET=your-jwt-secret-change-this-to-random-string
